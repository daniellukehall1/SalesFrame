# Browser-safe Supabase values. These must also be set in Netlify.
VITE_SUPABASE_URL=https://iuwjjxjicnorxlxzepup.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_miosbt6oQM8gT-IPp32u3Q_2_9yEzaP
VITE_LOGO_DEV_PUBLISHABLE_KEY=
# Conversation mode remains opt-in until its additive migration and smoke tests are complete.
VITE_CONVERSATION_UI_ENABLED=false

# Server-only Netlify Function secrets. Never expose these with a VITE_ prefix.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_KEY_ENCRYPTION_SECRET=

# Local Supabase CLI / migration use only. Do not add this to the browser app.
SUPABASE_DATABASE_URL=

# Optional OpenAI defaults used by Netlify Functions.
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_LIVE_STATE_MODEL=gpt-5.4-nano
OPENAI_LIVE_QUESTION_MODEL=gpt-5.4-mini
OPENAI_LIVE_COACH_MODEL=gpt-5.4-mini
# Dedicated Next Call override; the worker defaults directly to this model when omitted.
OPENAI_NEXT_CALL_BRIEF_MODEL=gpt-5.4-mini
# Dedicated tool-using workspace assistant; uses each workspace's encrypted OpenAI key.
OPENAI_WORKSPACE_ASSISTANT_MODEL=gpt-5.6-terra
# Server-side cost and incident kill switch. Enable only after the additive migration is validated.
WORKSPACE_ASSISTANT_ENABLED=false
OPENAI_ACCOUNT_ENRICHMENT_MODEL=gpt-5.4-mini
# Optional; falls back to OPENAI_ACCOUNT_ENRICHMENT_MODEL when omitted.
OPENAI_CONTACT_ENRICHMENT_MODEL=gpt-5.4-mini
OPENAI_RESEARCH_WEB_SEARCH=true
OPENAI_REQUEST_TIMEOUT_MS=25000
OPENAI_WEB_SEARCH_TIMEOUT_MS=45000

# Server-only Deepgram live transcription. Never expose this with a VITE_ prefix.
DEEPGRAM_API_KEY=
DEEPGRAM_FLUX_MODEL=flux-general-en
DEEPGRAM_DIARIZE_MODEL=latest
DEEPGRAM_FLUX_EAGER_EOT_THRESHOLD=0.4
DEEPGRAM_FLUX_EOT_THRESHOLD=0.75
DEEPGRAM_FLUX_EOT_TIMEOUT_MS=5000
DEEPGRAM_TOKEN_GRANT_TIMEOUT_MS=8000

# Recall.ai meeting bot. Every value below is server-only; never use a VITE_ prefix.
# Keep disabled until key rotation, the additive migration, signed webhook tests,
# cross-platform smoke tests, and legal/privacy approval are complete.
RECALL_MEETING_BOT_ENABLED=false
RECALL_REGION=us-west-2
RECALL_API_KEY=
RECALL_WORKSPACE_VERIFICATION_SECRET=
# Only legacy Recall dashboard webhooks created before 15 December 2025 need this.
RECALL_SVIX_WEBHOOK_SECRET=
# Generate at least 32 random bytes and keep this stable while encrypted jobs exist.
MEETING_BOT_CRYPTO_SECRET=

# Calm capacity defaults. Limits must satisfy user <= workspace <= global.
MEETING_BOT_MAX_PER_USER=1
MEETING_BOT_MAX_PER_WORKSPACE=5
MEETING_BOT_MAX_GLOBAL=25
MEETING_BOT_RATE_WINDOW_MINUTES=60
MEETING_BOT_USER_ROLLING_CREATION_LIMIT=3
MEETING_BOT_WORKSPACE_ROLLING_CREATION_LIMIT=15
MEETING_BOT_USER_DAILY_BOT_LIMIT=12
MEETING_BOT_WORKSPACE_DAILY_BOT_LIMIT=60
MEETING_BOT_USER_DAILY_MINUTE_LIMIT=480
MEETING_BOT_WORKSPACE_DAILY_MINUTE_LIMIT=2400
MEETING_BOT_RESERVED_MINUTES=120

# Exact comma-separated hosts Recall uses for short-lived transcript/audio downloads.
# Do not use wildcard domains. Confirm the current us-west-2 hosts from signed sandbox artifacts.
RECALL_MEDIA_DOWNLOAD_HOSTS=

# Optional canonical public origin and same-origin 1280x720 JPEG overrides.
# Netlify's URL variable and /media/salesframe-meeting-bot.jpg are used by default.
RECALL_PUBLIC_BASE_URL=
RECALL_BOT_IMAGE_URL=
# Prefer the deployed same-origin image. Base64 is supported only as an operational fallback.
RECALL_BOT_IMAGE_B64=

# Server-only Netlify Function secrets. Never expose these with a VITE_ prefix.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_KEY_ENCRYPTION_SECRET=

# Local Supabase CLI / migration use only. Do not add this to the browser app.
SUPABASE_DATABASE_URL=

# Optional OpenAI defaults used by Netlify Functions.
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_LIVE_STATE_MODEL=gpt-5.4-nano
OPENAI_LIVE_QUESTION_MODEL=gpt-5.4-mini
OPENAI_LIVE_COACH_MODEL=gpt-5.4-mini
OPENAI_ACCOUNT_ENRICHMENT_MODEL=gpt-5.4-mini
OPENAI_RESEARCH_WEB_SEARCH=true

# Server-only Deepgram live transcription. Never expose this with a VITE_ prefix.

{
  "name": "salesframe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "check": "pnpm check:secrets && pnpm lint && pnpm test && pnpm build",
    "check:secrets": "node scripts/check-secrets.mjs",
    "lint": "tsc -b --pretty false",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test \"tests/**/*.test.mjs\"",
    "test:e2e": "node --test \"tests/e2e/**/*.test.mjs\"",
    "test:functions": "node --test \"tests/functions/**/*.test.mjs\"",
    "deploy:status": "pnpm dlx netlify status",
    "deploy:prod": "pnpm dlx netlify deploy --prod --build",
    "sync:supabase-email-templates": "node scripts/sync-supabase-email-templates.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-react": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "papaparse": "^5.5.4",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vaul": "^1.1.2",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "shadcn": "^4.13.0"
  }
}
